<%- include('partials_header') %>
<h1>Ranking</h1>
<section class="card">
  <table>
    <thead><tr><th>#</th><th>Usuario</th><th>Puntos</th><th>Exactos</th><th>Ganador/empate</th></tr></thead>
    <tbody>
      <% ranking.forEach((r, i) => { %>
        <tr>
          <td><%= i + 1 %></td>
          <td><%= r.name %></td>
          <td><strong><%= r.points %></strong></td>
          <td><%= r.exacts %></td>
          <td><%= r.hits %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>
<%- include('partials_footer') %>
